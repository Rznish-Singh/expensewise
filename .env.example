# ── Database (Neon Postgres / Supabase) ────────────────────────────────────────
# Neon (recommended):
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/spendwise?sslmode=require

# Supabase alternative:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
